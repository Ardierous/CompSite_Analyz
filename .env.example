# Скопируйте в .env и заполните (файл .env в Git не коммитить).
# cp .env.example .env

# OpenAI API (ProxyAPI)
OPENAI_API_KEY=your_proxyapi_key_here
OPENAI_API_BASE=https://api.proxyapi.ru/openai/v1

# Flask (приложение слушает 5000 внутри контейнера app)
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# Опционально: телеметрия CrewAI
# CREWAI_TELEMETRY_OPT_OUT=1
# CREWAI_TRACING_ENABLED=false
